# ====== Hypergrow — variáveis de ambiente ======
# Copie este arquivo para ".env.local" e preencha os valores.
# NUNCA suba o .env.local para o GitHub (já está no .gitignore).

# --- Supabase (banco de leads) ---
# Pegue em: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave secreta (service_role) — usada só no servidor para salvar leads
SUPABASE_SERVICE_ROLE_KEY=

# --- WhatsApp (botão de contato) ---
# Número com DDI e DDD, só dígitos. Ex: 5532999999999
NEXT_PUBLIC_WHATSAPP=

# --- Painel admin / CRM ---
# Senha para entrar em /admin (escolha uma forte)
ADMIN_PASSWORD=
# Segredo para assinar a sessão do admin (string aleatória longa)
ADMIN_SECRET=

# --- Agente de IA (OpenAI) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Agendamento de reunião (Cal.com) ---
# Seu link público do Cal.com (ex: hypergrow/reuniao)
# NEXT_PUBLIC_CALCOM_LINK=

# --- E-mail (quando tiver Resend/SendGrid) ---
# RESEND_API_KEY=
# LEAD_NOTIFY_EMAIL=
